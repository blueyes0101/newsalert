<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.newsalert.client.ui.RecentResultsController"
            prefWidth="800" prefHeight="500">

    <!-- ── Top toolbar ────────────────────────────────────────────────── -->
    <top>
        <HBox spacing="8" style="-fx-padding: 12; -fx-background-color: #f5f5f5;
                                  -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
            <Button text="Refresh" onAction="#onRefresh"
                    style="-fx-background-color: #1a73e8; -fx-text-fill: white;"/>
        </HBox>
    </top>

    <!-- ── Results table ──────────────────────────────────────────────── -->
    <center>
        <TableView fx:id="resultsTable" BorderPane.alignment="CENTER">
            <columns>
                <TableColumn fx:id="colTitle"        text="Title"          prefWidth="340"/>
                <TableColumn fx:id="colSource"       text="Source / URL"   prefWidth="280"/>
                <TableColumn fx:id="colDiscoveredAt" text="Discovered"     prefWidth="160"/>
            </columns>
            <placeholder><Label text="No results yet. Click Refresh."/></placeholder>
        </TableView>
    </center>

    <!-- ── Status bar ─────────────────────────────────────────────────── -->
    <bottom>
        <HBox style="-fx-padding: 6 12; -fx-background-color: #fafafa;
                     -fx-border-color: #e0e0e0; -fx-border-width: 1 0 0 0;">
            <Label fx:id="statusLabel" text="Loading…" style="-fx-text-fill: #666666;"/>
        </HBox>
    </bottom>

</BorderPane>
